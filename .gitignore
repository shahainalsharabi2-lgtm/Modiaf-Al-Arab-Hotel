# Root ignores for monorepo (angular + aspnet-core)

# Dependencies
**/node_modules/
node_modules/

# Build outputs
**/bin/
**/obj/
**/dist/
**/.angular/
**/Logs/
**/publish/
**/tmp-build/

# IDE / OS
.vs/
.idea/
*.user
*.suo
.DS_Store
Thumbs.db

# Secrets (never commit)
**/.env
**/.env.*
**/appsettings.secrets.json
**/appsettings.Neon.json
**/neon.connection.*
**/deploy/neon.connection.*
**/.neon/
**/secrets.json

# Logs / temp
*.log
*.tmp
**/tmp/
**/coverage/

# Package locks at root only (subprojects manage their own)
/package-lock.json
/yarn.lock
